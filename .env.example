PORT=5000
NODE_ENV=development
DATABASE_URL="postgresql://user:password@localhost:5432/skillo?schema=public"

# Auth — each token type MUST have a unique secret
JWT_SECRET="your_super_secret_jwt_key"
JWT_RESET_SECRET="your_password_reset_secret"
JWT_VERIFY_EMAIL_SECRET="your_email_verification_secret"

# Frontend
FRONTEND_URL=http://localhost:3000

# Email
EMAIL_USER="your_email@gmail.com"
EMAIL_PASS="your_app_password"

# Razorpay
RAZORPAY_KEY_ID="your_razorpay_key_id"
RAZORPAY_KEY_SECRET="your_razorpay_key_secret"
# RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
